<<setup, echo=FALSE, results=hide>>=
set.seed(30600)

rd_make_toy <- function(n = 2500, x_min = -2, x_max = 2, c = 0, tau = 1) {
  X <- runif(n, x_min, x_max)
  D <- as.numeric(X >= c)  # SRD: deterministic assignment at the cutoff

  f <- function(x) 2 + 0.6 * x + 0.5 * sin(2 * x)  # smooth baseline
  eps <- rnorm(n, mean = 0, sd = 0.6)

  Y0 <- f(X) + eps
  Y1 <- f(X) + tau + eps
  Y <- ifelse(D == 1, Y1, Y0)

  # Extra covariate (for continuity/balance demo): smooth in X, no jump at c
  Z <- 0.4 * X + rnorm(n, 0, 1)

  data.frame(Y = Y, D = D, X = X, Z = Z)
}

rd_ll_uniform <- function(df, c = 0, h = 0.5, y = "Y", x = "X") {
  xv <- df[[x]]
  yv <- df[[y]]

  left <- (xv < c) & (xv >= c - h)
  right <- (xv >= c) & (xv <= c + h)

  fit_l <- lm(yv[left] ~ I(xv[left] - c))
  fit_r <- lm(yv[right] ~ I(xv[right] - c))

  a_l <- coef(fit_l)[1]
  a_r <- coef(fit_r)[1]

  list(
    tau_hat = unname(a_r - a_l),
    a_l = unname(a_l),
    a_r = unname(a_r),
    n_l = sum(left),
    n_r = sum(right),
    fit_l = fit_l,
    fit_r = fit_r
  )
}

rd_bin_means <- function(df, c = 0, binwidth = 0.1, x_min = -2, x_max = 2) {
  x <- df$X
  y <- df$Y

  breaks_l <- seq(x_min, c, by = binwidth)
  breaks_r <- seq(c, x_max, by = binwidth)

  bins_l <- cut(x[x < c], breaks = breaks_l, include.lowest = TRUE, right = FALSE)
  bins_r <- cut(x[x >= c], breaks = breaks_r, include.lowest = TRUE, right = FALSE)

  mean_l <- tapply(y[x < c], bins_l, mean)
  mean_r <- tapply(y[x >= c], bins_r, mean)

  mid_l <- head(breaks_l, -1) + binwidth / 2
  mid_r <- head(breaks_r, -1) + binwidth / 2

  keep_l <- !is.na(mean_l)
  keep_r <- !is.na(mean_r)

  list(
    x_l = mid_l[keep_l], y_l = as.numeric(mean_l[keep_l]),
    x_r = mid_r[keep_r], y_r = as.numeric(mean_r[keep_r])
  )
}

toy <- rd_make_toy()
true_tau_at_c <- 1

rd_make_toy_frd <- function(n = 2500, x_min = -2, x_max = 2, c = 0, tau = 1) {
  X <- runif(n, x_min, x_max)
  Z <- as.numeric(X >= c)  # eligibility at cutoff (instrument)

  # Imperfect compliance: treatment probability shifts at c but is not 0/1.
  p <- pmin(pmax(0.20 + 0.55 * Z + 0.05 * (X - c), 0.02), 0.98)
  D <- rbinom(n, size = 1, prob = p)

  f <- function(x) 2 + 0.6 * x + 0.5 * sin(2 * x)  # smooth baseline
  eps <- rnorm(n, mean = 0, sd = 0.6)

  Y0 <- f(X) + eps
  Y1 <- f(X) + tau + eps
  Y <- ifelse(D == 1, Y1, Y0)

  data.frame(Y = Y, D = D, X = X, Z = Z)
}

toy_frd <- rd_make_toy_frd()

did_make_toy <- function(n_per_group = 400, t_vals = 0:5, t0 = 3, rho = 0.6) {
  t_vals <- as.integer(t_vals)
  n_t <- length(t_vals)
  n_units <- 2 * n_per_group

  id_unit <- seq_len(n_units)
  id <- rep(id_unit, each = n_t)
  t <- rep(t_vals, times = n_units)
  group <- rep(rep(c("control", "treated"), each = n_per_group), each = n_t)

  treated <- as.numeric(group == "treated")
  post <- as.numeric(t >= t0)
  D <- treated * post

  # Unit effects induce serial correlation concerns in naive DiD SEs.
  alpha_i_unit <- rnorm(n_units, mean = 0, sd = 1.0)
  alpha_i <- rep(alpha_i_unit, each = n_t)

  # AR(1) shock within unit (simple construction; sigma scaled to keep Var ~ 1).
  eps <- numeric(length(id))
  for (u in id_unit) {
    idx <- which(id == u)
    e <- numeric(n_t)
    e[1] <- rnorm(1, 0, 1)
    for (j in 2:n_t) {
      e[j] <- rho * e[j - 1] + rnorm(1, 0, sqrt(1 - rho^2))
    }
    eps[idx] <- e
  }

  level_gap <- 0.8 * treated
  common_trend <- 0.30 * t

  # Dynamic treatment effect post (keeps parallel trends in levels under no treatment).
  te <- 1.2 + 0.2 * pmax(0, t - t0)

  Y0 <- 2.0 + level_gap + common_trend + alpha_i + eps
  Y <- Y0 + D * te

  data.frame(id = id, t = t, group = group, treated = treated, post = post, D = D, Y = Y)
}

did_toy <- did_make_toy()

did_make_staggered_toy <- function(
  n_per_group = 250,
  t_vals = 0:7,
  g_early = 3,
  g_late = 5,
  rho = 0.6
) {
  t_vals <- as.integer(t_vals)
  n_t <- length(t_vals)

  groups <- c("never", "early", "late")
  n_units <- length(groups) * n_per_group
  id_unit <- seq_len(n_units)

  id <- rep(id_unit, each = n_t)
  t <- rep(t_vals, times = n_units)
  group <- rep(rep(groups, each = n_per_group), each = n_t)

  G_unit <- ifelse(group == "early", g_early, ifelse(group == "late", g_late, Inf))
  G <- as.numeric(G_unit)
  D <- as.numeric(t >= G_unit)

  # Unit effects + AR(1) within-unit shocks (so serial correlation is present).
  alpha_i_unit <- rnorm(n_units, mean = 0, sd = 1.0)
  alpha_i <- rep(alpha_i_unit, each = n_t)

  eps <- numeric(length(id))
  for (u in id_unit) {
    idx <- which(id == u)
    e <- numeric(n_t)
    e[1] <- rnorm(1, 0, 1)
    for (j in 2:n_t) {
      e[j] <- rho * e[j - 1] + rnorm(1, 0, sqrt(1 - rho^2))
    }
    eps[idx] <- e
  }

  # Common trend + group level gaps (parallel trends in untreated outcomes).
  level_gap <- ifelse(group == "early", 0.6, ifelse(group == "late", 0.2, 0.0))
  common_trend <- 0.25 * t

  # Heterogeneous dynamic treatment effects by cohort:
  te_base <- ifelse(group == "early", 1.8, ifelse(group == "late", 0.8, 0.0))
  event_time <- t - G
  te_dyn <- te_base + 0.15 * pmax(0, event_time) + 0.10 * pmax(0, event_time)^2
  te <- ifelse(D == 1, te_dyn, 0.0)

  Y0 <- 2.0 + level_gap + common_trend + alpha_i + eps
  Y <- Y0 + te

  data.frame(
    id = id,
    t = t,
    group = group,
    G = G,
    D = D,
    event_time = event_time,
    te_true = te_dyn,
    Y = Y
  )
}

did_stag <- did_make_staggered_toy()
@

